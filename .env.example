# Copy to .env and fill values.
OPENAI_API_KEY=
OPENAI_BASE_URL=

SOURCE_LANGUAGE=auto
TARGET_LANGUAGE=ru

SPEAKER_NAME=
SAMPLE_RATE=16000
CHUNK_SECONDS=2.0
AUDIO_OVERLAP_SECONDS=0.6
SILENCE_RMS_THRESHOLD=0.004
AUDIO_QUEUE_MAX_CHUNKS=3

STT_PROVIDER=openai
STT_MODEL=gpt-4o-transcribe
STT_PROMPT=
TEXT_PROVIDER=openai
TEXT_MODEL=gpt-4o-mini
OPENAI_TEXT_API=chat

ENABLE_TRANSLATION=true
ENABLE_RAG_SUGGESTIONS=false
ENABLE_GENERAL_ADVICE=false
KNOWLEDGE_BASE_PATH=knowledge_base
RAG_MAX_CHUNKS=4
SUGGESTIONS_LANGUAGE=target

ENABLE_TRANSCRIPT_LOG=true
TRANSCRIPT_LOG_DIR=logs/transcripts

APP_HOST=127.0.0.1
APP_PORT=8787
AUTO_START=false
